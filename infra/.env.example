DOMAIN=atendefy.com.br
POSTGRES_USER=atendefy
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_CONNECTION=Host=postgres;Database=atendefy;Username=atendefy;Password=change_me_strong_password
REDIS_PASSWORD=change_me_redis_password
REDIS_CONNECTION=redis://:change_me_redis_password@redis:6379
JWT_SECRET=change_me_minimum_32_chars_secret_key_here_!!!
ENCRYPTION_KEY=change_me_minimum_32_chars_encryption_key_here
EVOLUTION_API_KEY=change_me_evolution_api_key
# Chave de admin p/ aprovar empresas (header X-Admin-Key em /tenants/pending e /activate).
# Vazio = endpoints admin desativados.
ADMIN_KEY=change_me_admin_key

# Anti-abuso do cadastro anônimo (Cloudflare Turnstile). Vazio = captcha desativado (NÃO em prod).
# Secret key (backend). O site key (público) é injetado no build do front via GitHub Actions
# variable VITE_TURNSTILE_SITE_KEY (Settings → Secrets and variables → Actions → Variables).
TURNSTILE_SECRET_KEY=

# SMTP para o e-mail de verificação de cadastro. Vazio = não envia (apenas loga o link).
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Mensagee

API_VERSION=latest
